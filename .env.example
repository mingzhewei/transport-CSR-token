# Copy this file to .env on the machine that runs the program.
# Do NOT commit real API keys or the real BRIDGE_TOKEN.

# ===== Internal computer: internal-bridge =====
# The company OpenAI-compatible base URL. For your CRS setup this is usually:
UPSTREAM_BASE_URL=https://crs.acerobotics.com/openai

# Put the real company API key only on the internal computer.
# Example placeholder; replace with your actual key.
UPSTREAM_API_KEY=cr_2b3be162dc2b8e64a860e0095d9eb6dc7f4a6d5e7d95cfeb6d9c6f0d353879f4

# A simple shared key used between the external-client and internal-bridge.
# It is NOT the company API key.
# Requirements: at least 32 characters, and not a simple sequential/predictable string.
# Generate one with: openssl rand -base64 32
BRIDGE_TOKEN=xK9mNpL2qR5tV8wY3zA6cF0hJ4kM7oP1

# Keep 127.0.0.1 when using `tailscale serve`.
# Use :8787 only if you intentionally expose the port on the machine network.
INTERNAL_LISTEN_ADDR=127.0.0.1:18787
DEFAULT_MODEL=gpt-5.5

# Optional. Comma-separated list of model IDs advertised by /models.
# If unset, only DEFAULT_MODEL is advertised.
# MODELS=gpt-5.5,gpt-5

# ===== External computer: external-client =====
# The internal computer URL exposed through Tailscale Serve.
# Example: https://your-mac.your-tailnet.ts.net/openai
REMOTE_BASE_URL=https://60281877w.tail22a8f2.ts.net/openai
EXTERNAL_LISTEN_ADDR=127.0.0.1:18788

# Optional but STRONGLY recommended. If set, local callers must use this key
# when calling external-client. Leave empty only on single-user machines.
EXTERNAL_API_KEY=xK9mNpL2qR5tV8wY3zA6cF0hJ4kM7oP1

# ===== Rate limiting (requests per minute) =====
# 0 means disabled. A reasonable default for personal use is 60-120.
RATE_LIMIT_RPM=60

# ===== Upstream timeout =====
# Time in milliseconds to wait for the upstream response headers.
UPSTREAM_TIMEOUT_MS=120000

# ===== Logging =====
# debug gives more detail; info is usually enough.
LOG_LEVEL=info

# Optional. If set, logs are written to this file and printed to the terminal.
# Use different paths on the two computers.
# macOS example: LOG_FILE=./logs/internal-bridge.log
# Windows example: LOG_FILE=.\\logs\\external-client.log
LOG_FILE=./logs/internal-bridge.log
